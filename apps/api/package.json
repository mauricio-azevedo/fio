{
  "name": "fio-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:generate && nest build",
    "dev": "pnpm db:generate && nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "pnpm db:generate && tsc -p tsconfig.json --noEmit",
    "test": "pnpm db:generate && vitest run",
    "lint": "eslint src",
    "db:generate": "prisma generate --config prisma.config.ts --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --config prisma.config.ts --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@types/express": "^5.0.5",
    "prisma": "^7.2.0"
  }
}
